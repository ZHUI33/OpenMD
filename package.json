{
  "name": "openmd",
  "version": "0.1.0",
  "description": "A focused, open-source Markdown desktop editor.",
  "main": "./out/main/index.js",
  "author": "OpenMD contributors",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "pnpm typecheck && electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dist:win": "pnpm build && electron-builder --win",
    "dist:mac": "pnpm build && electron-builder --mac"
  },
  "dependencies": {
    "@codemirror/language": "6.12.4",
    "@codemirror/language-data": "6.5.2",
    "@milkdown/core": "^7.21.2",
    "@milkdown/crepe": "^7.21.2",
    "@milkdown/kit": "^7.21.2",
    "@milkdown/prose": "^7.21.2",
    "@milkdown/react": "^7.21.2",
    "prosemirror-model": "^1.25.10",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.42.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zustand": "5.0.6"
  },
  "devDependencies": {
    "@eslint/js": "9.31.0",
    "@types/node": "24.13.2",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "4.6.0",
    "electron": "43.0.0",
    "electron-builder": "26.15.3",
    "electron-builder-squirrel-windows": "26.15.3",
    "electron-vite": "4.0.0",
    "eslint": "9.31.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.20",
    "globals": "16.3.0",
    "jsdom": "26.1.0",
    "prettier": "3.6.2",
    "typescript": "5.8.3",
    "typescript-eslint": "8.37.0",
    "vite": "7.3.3",
    "vitest": "3.2.4"
  },
  "pnpm": {
    "overrides": {
      "@electron/node-gyp": "https://codeload.github.com/electron/node-gyp/tar.gz/06b29aafb7708acef8b3669835c8a7857ebc92d2"
    },
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  }
}
